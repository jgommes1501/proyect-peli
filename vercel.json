{
  "buildCommand": "npm run build -- --configuration production",
  "outputDirectory": "www",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*).js",
      "headers": [{ "key": "Content-Type", "value": "application/javascript" }]
    },
    {
      "source": "/(.*).css",
      "headers": [{ "key": "Content-Type", "value": "text/css" }]
    }
  ]
}
